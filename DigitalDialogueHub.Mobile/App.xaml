<?xml version="1.0" encoding="UTF-8" ?>
<Application
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DigitalDialogueHub.Mobile"
    xmlns:converters="clr-namespace:DigitalDialogueHub.Mobile.Converters"
    x:Class="DigitalDialogueHub.Mobile.App">

    <Application.Resources>
        <ResourceDictionary>
            <!-- Konverteri kao direktni resursi -->
            <converters:SelectedCategoryBgConverter x:Key="SelectedCategoryBgConverter" />
            <converters:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:BoolToIconConverter x:Key="BoolToIconConverter" />

            <!-- Uvoz stilova -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>
