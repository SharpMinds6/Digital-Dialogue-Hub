<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:DigitalDialogueHub.Mobile.Converters"
    x:Class="DigitalDialogueHub.Mobile.Views.NotificationPage"
    Title="Notifications">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:BoolToIconConverter x:Key="BoolToIconConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <StackLayout Padding="10" Spacing="10">

        <Label Text="Notifications" FontSize="24" HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Notifications}" 
                        SelectionMode="None"
                        Margin="0,10,0,0">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="0,5" HasShadow="True" CornerRadius="8"
                           BackgroundColor="{Binding IsRead, Converter={StaticResource BoolToColorConverter}}">
                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Image Source="{Binding IsRead, Converter={StaticResource BoolToIconConverter}}" 
                                   WidthRequest="24" HeightRequest="24" />
                            <Label Text="{Binding Message}" 
                                   VerticalOptions="Center" 
                                   FontAttributes="Bold" 
                                   LineBreakMode="TailTruncation" />
                        </StackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <Button Text="Refresh" Command="{Binding LoadNotificationsCommand}" />

    </StackLayout>

</ContentPage>
