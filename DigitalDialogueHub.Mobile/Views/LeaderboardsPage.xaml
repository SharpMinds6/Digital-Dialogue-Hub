<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:DigitalDialogueHub.Mobile.DTOs"
             xmlns:viewmodels="clr-namespace:DigitalDialogueHub.Mobile.ViewModels"
             x:Class="DigitalDialogueHub.Mobile.Views.LeaderboardsPage"
             x:DataType="viewmodels:LeaderboardsPageViewModel"
             Title="Leaderboard">

    <StackLayout Padding="20">

        <!-- Header -->
        <Label Text="Leaderboard" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" />

        <!-- User Info -->
        <Label Text="{Binding Username}" FontSize="18" HorizontalOptions="Center" />
        <Label Text="{Binding Email}" FontSize="14" HorizontalOptions="Center" TextColor="Gray" />

        <BoxView HeightRequest="1" BackgroundColor="LightGray" Margin="0,10" />

        <!-- Leaderboard List -->
        <CollectionView ItemsSource="{Binding Leaderboards}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:LeaderboardDto">
                    <Grid Padding="10" ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0"
                               Text="{Binding Rank}" 
                               FontSize="18" 
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               Margin="0,0,10,0"/>
                        <Label Grid.Column="1"
                               Text="{Binding UserId, StringFormat='User ID: {0}'}" 
                               FontSize="16"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2"
                               Text="{Binding Points}" 
                               FontSize="16" 
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               HorizontalOptions="End" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>
