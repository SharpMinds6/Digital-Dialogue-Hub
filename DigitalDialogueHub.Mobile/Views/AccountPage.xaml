<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DigitalDialogueHub.Mobile.Views.AccountPage"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header: strelica nazad i naslov -->
        <Grid Padding="20,40,20,10" ColumnDefinitions="Auto,*">
            <Image Source="icon_back.png"
                   HeightRequest="24"
                   WidthRequest="24"
                   VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>
            <Label Text="My Account"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Grid.Column="1" />
        </Grid>

        <!-- Avatar + user info -->
        <VerticalStackLayout Grid.Row="1" Padding="30,0,30,10" Spacing="8" HorizontalOptions="Center">
            <Image Source="image3.png" HeightRequest="100" WidthRequest="100" />
            <Label Text="{Binding Username}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
            <Label Text="{Binding Email}" FontSize="14" TextColor="Gray" HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Opcije -->
        <Frame Grid.Row="2"
               CornerRadius="30"
               Padding="20"
               Margin="20"
               BackgroundColor="#F4F4F4"
               HasShadow="True">
            <VerticalStackLayout Spacing="15">
                <Button Text="🛠 Edit profile" Command="{Binding EditProfileCommand}"
                        BackgroundColor="Transparent" TextColor="Black" />
                <Button Text="🏅 Badges" Command="{Binding OpenBadgesCommand}"
                        BackgroundColor="Transparent" TextColor="Black" />
                <Button Text="📘 My posts" Command="{Binding MyPostsCommand}"
                        BackgroundColor="Transparent" TextColor="Black" />
                <Button Text="⚙ Settings" Command="{Binding SettingsCommand}"
                        BackgroundColor="Transparent" TextColor="Black" />
                <Button Text="Log out"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="#D6ECFA"
                        TextColor="Black"
                        CornerRadius="25"
                        WidthRequest="250"
                        HeightRequest="50"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
