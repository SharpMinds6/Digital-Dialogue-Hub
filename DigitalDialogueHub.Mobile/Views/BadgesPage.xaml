<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dtos="clr-namespace:DigitalDialogueHub.Mobile.DTOs"
             xmlns:viewmodels="clr-namespace:DigitalDialogueHub.Mobile.ViewModels"
             x:Class="DigitalDialogueHub.Mobile.Views.BadgesPage"
             Title="My Badges"
             BackgroundColor="White">

    <RefreshView IsRefreshing="{Binding IsLoading}" Command="{Binding RefreshCommand}">
        <CollectionView ItemsSource="{Binding Badges}" Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5" CornerRadius="10" BorderColor="LightGray">
                        <HorizontalStackLayout>
                            <Image Source="{Binding IconPath}" WidthRequest="40" HeightRequest="40" />
                            <VerticalStackLayout Padding="10,0">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="Medium" />
                                <Label Text="{Binding Description}" FontSize="Small" TextColor="Gray"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>


