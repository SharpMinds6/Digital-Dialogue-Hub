<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DigitalDialogueHub.Mobile.ViewModels"
             xmlns:dtos="clr-namespace:DigitalDialogueHub.Mobile.DTOs"
             x:Class="DigitalDialogueHub.Mobile.Views.MyPostsPage"
             x:DataType="viewmodels:MyPostsPageViewModel"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">


    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Padding="20,40,20,10" ColumnDefinitions="Auto,*">
            <Image Source="icon_back.png"
                   HeightRequest="24"
                   WidthRequest="24"
                   VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped" />
                </Image.GestureRecognizers>
            </Image>
            <Label Text="My Posts"
                   FontSize="20"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   Grid.Column="1" />
        </Grid>

        <!-- Posts List -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding MyPosts}"
                        Margin="20,0"
                        ItemsLayout="VerticalList">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dtos:PostDto">
                    <Frame Margin="0,10" Padding="15" BackgroundColor="#F8F8F8" CornerRadius="15" HasShadow="True">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" TextColor="Black" />
                            <Label Text="{Binding Content}" FontSize="14" TextColor="#444" />
                            <Image Source="{Binding Image}" Aspect="AspectFill" HeightRequest="180" IsVisible="{Binding HasImage}" />
                            <HorizontalStackLayout Spacing="15">
                                <HorizontalStackLayout Spacing="5">
                                    <Image Source="like_icon.png" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="{Binding Likes}" FontSize="12" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5">
                                    <Image Source="vector.png" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="{Binding Dislikes}" FontSize="12" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5">
                                    <Image Source="comment_icon.png" WidthRequest="20" HeightRequest="20" />
                                    <Label Text="{Binding Comments}" FontSize="12" />
                                </HorizontalStackLayout>
                                <Image Source="share_icon.png" WidthRequest="20" HeightRequest="20" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>


