<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewmodels="clr-namespace:DigitalDialogueHub.Mobile.ViewModels"
    xmlns:dtos="clr-namespace:DigitalDialogueHub.Mobile.DTOs"
    x:Class="DigitalDialogueHub.Mobile.Views.CategorySelectionPopup"
   x:DataType="viewmodels:CategorySelectionPopupViewModel"
    x:Name="CategoryPopupRoot"
    Color="Transparent">

    <Border
        BackgroundColor="White"
        Stroke="#dbeafe"
        StrokeThickness="2"
        Padding="15"
        Margin="20"
        WidthRequest="350"
        HorizontalOptions="Center"
        VerticalOptions="Center"
        StrokeShape="RoundRectangle 30">

        <VerticalStackLayout Spacing="15">
            <Label Text="Choose category"
                   FontSize="18"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,5,0,10"/>

            <CollectionView ItemsSource="{Binding Categories}"
                            SelectionMode="Single"
                            HeightRequest="420">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dtos:CategoryDto">
                        <Frame CornerRadius="16" Padding="10" Margin="2"
                               BackgroundColor="{Binding IsSelected, Converter={StaticResource SelectedCategoryBgConverter}}">
                            <HorizontalStackLayout Spacing="12">
                                <Image Source="{Binding IconPath}" WidthRequest="26" HeightRequest="26" />
                                <Label Text="{Binding Name}" FontSize="15" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding BindingContext.SelectCategoryCommand, Source={x:Reference CategoryPopupRoot}}" CommandParameter="{Binding .}" />
                            </Frame.GestureRecognizers>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
