<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DigitalDialogueHub.Mobile.ViewModels"
             x:Class="DigitalDialogueHub.Mobile.Views.UserBadgesPage"
             Title="User Badges"
             BackgroundColor="#F9FAFB">

   
    <CollectionView ItemsSource="{Binding UserBadges}" Margin="10">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Frame CornerRadius="20" Padding="15" Margin="5"
                       BackgroundColor="White"
                       HasShadow="True"
                       BorderColor="#E0E7FF">
                    <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                        <!-- Ikona bedža (zamijeni izvor slike ako imaš) -->
                        <Image Source="badge_icon.png"
                               WidthRequest="40"
                               HeightRequest="40"
                               VerticalOptions="Center" />

                        <VerticalStackLayout VerticalOptions="Center" Spacing="3">
                            <!-- Pretpostavimo da DTO ima Title i Description, ako nema, možeš ih dodati -->
                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   FontSize="16"
                                   TextColor="#1E3A8A" />

                            <Label Text="{Binding Description}"
                                   FontSize="13"
                                   TextColor="#6B7280"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation" />

                            <Label Text="{Binding EarnedAt, StringFormat='Earned at: {0:dd.MM.yyyy}'}"
                                   FontSize="12"
                                   TextColor="#9CA3AF" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
