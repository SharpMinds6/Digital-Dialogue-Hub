<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DigitalDialogueHub.Mobile.ViewModels"
             x:Class="DigitalDialogueHub.Mobile.Views.SettingsPage">


    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Settings" FontSize="24" HorizontalOptions="Center" />

            <Label Text="Username" />
            <Entry Text="{Binding Username}" Placeholder="Enter username" />

            <Label Text="Email" />
            <Entry Text="{Binding Email}" Placeholder="Enter email" Keyboard="Email" />

            <Button Text="Save"
                    Command="{Binding SaveCommand}"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    CornerRadius="8" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
