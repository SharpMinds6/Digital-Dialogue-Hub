<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DigitalDialogueHub.Mobile.ViewModels"
             x:Class="DigitalDialogueHub.Mobile.Views.ChangePasswordPage"
             x:DataType="viewmodels:ChangePasswordPageViewModel"
             BackgroundColor="White"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.BindingContext>
        <viewmodels:ChangePasswordPageViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Header -->
        <Grid Padding="20,40,20,10" ColumnDefinitions="Auto,*">
            <Image Source="icon_back.png"
                   HeightRequest="24"
                   WidthRequest="24"
                   VerticalOptions="Center">
                <Image.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackTapped"/>
                </Image.GestureRecognizers>
            </Image>
            <Label Text="Password"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Grid.Column="1"/>
        </Grid>

        <!-- Avatar -->
        <VerticalStackLayout Grid.Row="1" Spacing="12" HorizontalOptions="Center">
            <Image Source="image3.png" HeightRequest="90" WidthRequest="90" Margin="0,0,0,8" />
        </VerticalStackLayout>

        <!-- Card with fields -->
        <Frame Grid.Row="2"
               CornerRadius="30"
               Padding="25"
               Margin="24,8"
               BackgroundColor="#F6F6F6"
               HasShadow="True"
               HorizontalOptions="Center"
               VerticalOptions="Center"
               WidthRequest="320">
            <VerticalStackLayout Spacing="16">
                <Entry Placeholder="Current password"
                       IsPassword="True"
                       Text="{Binding CurrentPassword}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="#999"
                       FontSize="15"/>

                <Entry Placeholder="New password"
                       IsPassword="True"
                       Text="{Binding NewPassword}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="#999"
                       FontSize="15"/>

                <Entry Placeholder="Confirm new password"
                       IsPassword="True"
                       Text="{Binding ConfirmPassword}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="#999"
                       FontSize="15"/>

                <Button Text="Save new password"
                        Command="{Binding SavePasswordCommand}"
                        BackgroundColor="#C4DFFF"
                        TextColor="Black"
                        FontAttributes="Bold"
                        WidthRequest="230"
                        HeightRequest="50"
                        CornerRadius="25"
                        HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>

